# Copy to .env and adjust
#
# AgentForge reads these env vars automatically:
#   - AGENTFORGE_LOG_FORMAT (text|json, default: text)
#   - AGENTFORGE_LOG_LEVEL (DEBUG|INFO|WARNING|ERROR, default: INFO)
#   - OTEL_EXPORTER_OTLP_ENDPOINT (optional, for OTLP/HTTP metrics push)
#   - OPENROUTER_API_KEY / OPENAI_API_KEY / etc. (LLM provider keys)
#
# Other paths (mailbox, state, tenants, usage, runs) are passed as CLI
# args to `agentforge serve`. The Dockerfile already provides sensible
# defaults under /app/data.
#
# Dashboard auth: login uses a tenant's API key. Create one with
# `docker compose exec agentforge agentforge tenants add <id>` and
# paste the printed key into the dashboard login form.

# --- Core ---
AGENTFORGE_LOG_LEVEL=INFO
AGENTFORGE_LOG_FORMAT=json

# --- LLM providers (uncomment + set) ---
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...

# --- OpenTelemetry (optional) ---
# Push metrics to a collector every 30s.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
