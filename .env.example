# Copy to .env and adjust. Compose reads this via env_file:.

# --- Core ---
AGENTFORGE_LOG_LEVEL=INFO
AGENTFORGE_LOG_FORMAT=json
AGENTFORGE_MAX_BODY_BYTES=1048576

# --- Retention (v0.13.0) ---
# 0 = disabled. Default: 90 days for runs, 30 days for events.
AGENTFORGE_RETENTION_RUNS_DAYS=90
AGENTFORGE_RETENTION_EVENTS_DAYS=30
AGENTFORGE_RETENTION_INTERVAL_HOURS=6

# --- LLM providers (uncomment + set) ---
# OPENROUTER_API_KEY=***
# OPENAI_API_KEY=***
# MINIMAX_API_KEY=***
# OLLAMA_HOST=http://host.docker.internal:11434

# --- OpenTelemetry (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
